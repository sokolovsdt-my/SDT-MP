# Скопируй в .env.local и заполни реальными значениями
# (для git worktree: cp /path/to/main/.env.local ./.env.local).
#
# Supabase — публичные значения, видны в URL проекта и в анонимном ключе.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=

# Firebase Cloud Messaging — для веб-пушей.
# apiKey тут тоже публичный (он отдаётся в browser bundle), не считается секретом.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
